# Luna Chess Web App Configuration
# Copy this file to .env and adjust values as needed

# Server Configuration
HOST=127.0.0.1
PORT=5000
DEBUG=false

# Model Configuration
DEVICE=cuda  # Options: cuda, mps, cpu
MCTS_SIMS=50  # Number of MCTS simulations per move (10-200)
CHECKPOINT_DIR=./temp/
CHECKPOINT_FILE=best.pth.tar

# Logging
VERBOSE=true
LOG_LEVEL=INFO

# Optional: Production Server (if using gunicorn)
WORKERS=4
TIMEOUT=120
